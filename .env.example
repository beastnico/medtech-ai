# MedTech AI Environment Variables
# Copy this file to .env and fill in your actual values

# Required: Groq API Key (Get free key from https://console.groq.com)
GROQ_API_KEY=gorq_api_token_here

# Optional: HuggingFace API Token (if using HuggingFace models)
HUGGINGFACEHUB_API_TOKEN=huggingface_token_here

# Application Settings (optional - defaults in config.py)
# LOG_LEVEL=INFO
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50